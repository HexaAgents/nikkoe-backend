                <mxCell id="k-l3" value="Network" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="390" y="98" width="60" height="18" as="geometry"/></mxCell>
                <mxCell id="k-dot4" value="" style="ellipse;fillColor=#4A148C;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="460" y="100" width="14" height="14" as="geometry"/></mxCell>
                <mxCell id="k-l4" value="Server-side logic" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="480" y="98" width="110" height="18" as="geometry"/></mxCell>
                <mxCell id="k-dot5" value="" style="ellipse;fillColor=#37474F;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="600" y="100" width="14" height="14" as="geometry"/></mxCell>
                <mxCell id="k-l5" value="Supabase Auth" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="620" y="98" width="90" height="18" as="geometry"/></mxCell>
                <mxCell id="k-dot6" value="" style="ellipse;fillColor=#C62828;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="720" y="100" width="14" height="14" as="geometry"/></mxCell>
                <mxCell id="k-l6" value="Error path" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="740" y="98" width="70" height="18" as="geometry"/></mxCell>
                <mxCell id="k-dot7" value="" style="ellipse;fillColor=#F9A825;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="820" y="100" width="14" height="14" as="geometry"/></mxCell>
                <mxCell id="k-l7" value="Decision" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="840" y="98" width="60" height="18" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 1: APP BOOTSTRAP                                -->
                <!-- ======================================================= -->
                <mxCell id="sh1" value="APP BOOTSTRAP" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="136" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n1" value="User opens the app in their browser" style="ellipse;whiteSpace=wrap;fontSize=10;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;shadow=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="370" y="176" width="280" height="50" as="geometry"/></mxCell>

                <mxCell id="n2" value="main.tsx runs: calls posthog.init() to start analytics tracking,&#10;then createRoot(document.getElementById(&quot;root&quot;)).render(&lt;App /&gt;)&#10;— hands control of the page to React&#10;📄 src/main.tsx : lines 6-11" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="246" width="400" height="64" as="geometry"/></mxCell>

                <mxCell id="n3" value="App.tsx nests provider components around the entire app:&#10;  QueryClientProvider — manages React Query data fetching/caching&#10;  BrowserRouter — enables URL-based navigation&#10;  AuthProvider — manages login state (session, user, loading)&#10;  AppRoutes — decides which page component to render for the URL&#10;📄 src/App.tsx : lines 19-33" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="330" width="420" height="88" as="geometry"/></mxCell>

                <mxCell id="n4" value="AuthProvider mounts. Inside useEffect (runs once on mount):&#10;  1. supabase.auth.onAuthStateChange(callback) — registers a listener.&#10;     Whenever session changes later, callback runs:&#10;       setSession(session), setUser(session?.user ?? null), setLoading(false)&#10;  2. supabase.auth.getSession() — checks localStorage for a saved token.&#10;     If found, sets session/user state immediately (user is already logged in).&#10;     If not found, session stays null (user needs to log in).&#10;  3. Returns cleanup: subscription.unsubscribe() to prevent memory leaks.&#10;Initial state: session=null, user=null, loading=true&#10;📄 src/contexts/AuthContext.tsx : lines 49-70&#10;📄 src/integrations/supabase/client.ts : lines 6-12 (Supabase client config)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="438" width="460" height="155" as="geometry"/></mxCell>

                <mxCell id="n5" value="AppRoutes checks the current URL against its route table.&#10;URL is /login → matches: &lt;Route path=&quot;/login&quot; element={&lt;Login /&gt;} /&gt;&#10;This route is NOT wrapped in &lt;ProtectedRoute&gt;, so it renders without auth.&#10;(Other routes like /sales ARE protected — they'd redirect to /login if no session.)&#10;📄 src/routes.tsx : line 26" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="613" width="420" height="78" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 2: LOGIN COMPONENT                              -->
                <!-- ======================================================= -->
                <mxCell id="sh2" value="LOGIN COMPONENT RENDERS" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="711" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n6" value="Login() function component executes. First, hooks run (lines 14-19):&#10;  const navigate = useNavigate()&#10;    — from react-router-dom; returns a function to change the URL&#10;  const { signIn } = useAuth()&#10;    — calls useContext(AuthContext) → returns auth object&#10;    — destructures just the signIn function from it&#10;    → signIn is defined at src/contexts/AuthContext.tsx : lines 72-87&#10;    → useAuth is defined at src/hooks/useAuth.ts : lines 4-9&#10;  const [email, setEmail] = useState(&quot;&quot;) — tracks email input value&#10;  const [password, setPassword] = useState(&quot;&quot;) — tracks password input value&#10;  const [loading, setLoading] = useState(false) — tracks if request is in flight&#10;  const [showPassword, setShowPassword] = useState(false) — password visibility toggle&#10;📄 src/pages/Login.tsx : lines 14-19" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="757" width="460" height="190" as="geometry"/></mxCell>

                <mxCell id="n7" value="JSX renders (lines 40-96): a centred Card containing:&#10;  • &lt;img&gt; — Nikko logo from src/assets/nikko-logo.png&#10;  • &lt;form onSubmit={handleLogin}&gt; — wraps inputs + button&#10;  • Email &lt;Input type=&quot;email&quot; required&gt; — browser validates email format,&#10;    value bound to email state, each keystroke calls setEmail(e.target.value)&#10;  • Password &lt;Input type={showPassword ? &quot;text&quot; : &quot;password&quot;} required&gt;&#10;    — value bound to password state, each keystroke calls setPassword(...)&#10;    — eye toggle button (type=&quot;button&quot; so it doesn't submit the form,&#10;      tabIndex={-1} so keyboard users skip it): onClick toggles showPassword&#10;  • &lt;Button type=&quot;submit&quot; disabled={loading}&gt; — when loading is true, shows&#10;    &lt;Loader2&gt; spinner icon and button is disabled to prevent double-submit&#10;📄 src/pages/Login.tsx : lines 40-96" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="967" width="460" height="170" as="geometry"/></mxCell>

                <mxCell id="n8" value="User types email and password into the fields, then clicks &quot;Sign in&quot;&#10;(or presses Enter — same effect since button is type=&quot;submit&quot; inside a &lt;form&gt;)&#10;→ The form's onSubmit event fires, which calls handleLogin(e)&#10;📄 src/pages/Login.tsx : line 52" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="300" y="1157" width="420" height="64" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 3: handleLogin                                  -->
                <!-- ======================================================= -->
                <mxCell id="sh3" value="handleLogin EXECUTES (Login.tsx lines 21-37)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1241" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n9" value="Line 22: e.preventDefault()&#10;  Stops the browser's default form submission (which would POST to the&#10;  current URL and reload the page). We handle submission in JS instead.&#10;Line 23: setLoading(true)&#10;  Sets loading state to true → button becomes disabled, spinner appears.&#10;  Prevents user from clicking &quot;Sign in&quot; again while the request is pending.&#10;📄 src/pages/Login.tsx : lines 22-23" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="1287" width="420" height="100" as="geometry"/></mxCell>

                <mxCell id="n10" value="Line 25: const { user, error } = await signIn(email, password)&#10;  Calls signIn (from useAuth hook) passing the current email and password state.&#10;  await pauses handleLogin here until signIn resolves.&#10;  signIn always returns { user, error } — never throws.&#10;  We destructure the result into two variables.&#10;📄 src/pages/Login.tsx : line 25&#10;→ signIn defined at src/contexts/AuthContext.tsx : lines 72-87&#10;→ useAuth defined at src/hooks/useAuth.ts : lines 4-9" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="1407" width="440" height="118" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 4: signIn INTERNALS                             -->
                <!-- ======================================================= -->
                <mxCell id="sh4" value="INSIDE signIn (AuthContext.tsx lines 72-87)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1545" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n11" value="signIn is wrapped in try/catch. This guarantees it never throws —&#10;it always returns { user: ..., error: null } or { user: null, error: ... }.&#10;The caller (handleLogin) just checks if error is null, no try/catch needed.&#10;📄 src/contexts/AuthContext.tsx : lines 72-87" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="1591" width="400" height="64" as="geometry"/></mxCell>

                <mxCell id="n12" value="Line 74: const data = await authFetch&lt;AuthSessionResponse&gt;(&quot;/auth/login&quot;, { email, password })&#10;  Calls authFetch — a helper function defined at lines 9-25 in the same file.&#10;  The &lt;AuthSessionResponse&gt; is a TypeScript type (lines 27-35) describing the&#10;  expected response shape: { user: {id, email}, session: {tokens...} | null }&#10;📄 src/contexts/AuthContext.tsx : line 74 → function at lines 9-25" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="1675" width="440" height="78" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 5: authFetch INTERNALS                          -->
                <!-- ======================================================= -->
                <mxCell id="sh5" value="INSIDE authFetch (AuthContext.tsx lines 9-25)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1773" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n13" value="Line 10: const session = (await supabase.auth.getSession()).data.session&#10;  Reads any existing session token from the Supabase client (stored in&#10;  localStorage). On first login this is null. On subsequent calls from&#10;  other auth endpoints (e.g. change-password) it would carry the active token.&#10;📄 src/contexts/AuthContext.tsx : line 10&#10;→ supabase client at src/integrations/supabase/client.ts : lines 6-12" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="1819" width="440" height="88" as="geometry"/></mxCell>

                <mxCell id="n14" value="Lines 11-18: const res = await fetch(url, { method: &quot;POST&quot;, headers, body })&#10;  URL: ${VITE_API_URL}/auth/login  (e.g. https://api.nikkoe.com/api/auth/login)&#10;  Headers: Content-Type: application/json&#10;           Authorization: Bearer &lt;token&gt; (if session exists, otherwise omitted)&#10;  Body: JSON.stringify({ email, password })&#10;📄 src/contexts/AuthContext.tsx : lines 11-18" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="1927" width="440" height="88" as="geometry"/></mxCell>

                <!-- NETWORK -->
                <mxCell id="sh6" value="NETWORK — request leaves the browser" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="2035" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n15" value="HTTP POST sent to backend server&#10;Body: { &quot;email&quot;: &quot;user@example.com&quot;, &quot;password&quot;: &quot;...&quot; }" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="2081" width="340" height="42" as="geometry"/></mxCell>

                <mxCell id="en" value="NETWORK ERROR — fetch() throws&#10;(no internet, DNS failure, server down, timeout)&#10;Caught by signIn's catch block → returns { user: null, error }" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="2078" width="240" height="55" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 7: BACKEND                                      -->
                <!-- ======================================================= -->
                <mxCell id="sh7" value="BACKEND — FastAPI receives the request" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="2143" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n16" value="FastAPI matches POST /api/auth/login to @router.post(&quot;/login&quot;)&#10;on the auth router (prefix=&quot;/api/auth&quot;).&#10;No Depends(get_current_user) — this endpoint is intentionally unauthenticated&#10;because the user doesn't have a token yet.&#10;📄 app/routers/auth.py : lines 8, 11-12" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="2189" width="420" height="78" as="geometry"/></mxCell>

                <mxCell id="n17" value="Pydantic auto-validates the JSON body against LoginInput before login() runs:&#10;  email: EmailStr — rejects malformed emails (e.g. &quot;not-an-email&quot;) at this stage&#10;  password: str   — any string (no min_length for login, unlike SignupInput)&#10;📄 app/schemas.py : lines 138-140" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="2287" width="420" height="64" as="geometry"/></mxCell>

                <mxCell id="d1" value="Valid&#10;email format?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="2371" width="180" height="80" as="geometry"/></mxCell>

                <mxCell id="e1" value="Pydantic raises ValidationError → validation_error_handler() catches it&#10;Returns HTTP 400: { &quot;error&quot;: &quot;Validation failed&quot;, &quot;details&quot;: [...] }&#10;📄 app/errors.py : lines 39-41" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="2381" width="270" height="50" as="geometry"/></mxCell>

                <mxCell id="n18" value="login(body: LoginInput) function runs (line 12).&#10;Inside a try block, it calls:&#10;  supabase.auth.sign_in_with_password({ email: body.email, password: body.password })&#10;The backend Supabase client uses the SERVICE_ROLE_KEY (admin key stored in .env,&#10;never exposed to the browser). This gives the backend full auth admin access.&#10;📄 app/routers/auth.py : lines 12-16&#10;📄 app/dependencies.py : line 4 (create_client with SERVICE_ROLE_KEY)&#10;📄 app/config.py : lines 5-6 (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="2471" width="460" height="118" as="geometry"/></mxCell>

                <!-- SUPABASE -->
                <mxCell id="sh8" value="SUPABASE AUTH — credential check" style="rounded=0;fillColor=#37474F;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="2609" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n19" value="Supabase looks up the email in its auth.users table.&#10;If found, it compares the submitted password against the stored bcrypt hash." style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#ECEFF1;strokeColor=#37474F;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="2655" width="340" height="42" as="geometry"/></mxCell>

                <mxCell id="d2" value="Credentials&#10;correct?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="2717" width="180" height="80" as="geometry"/></mxCell>

                <mxCell id="e2" value="Wrong email or password — Supabase throws an exception.&#10;Caught by except block (line 17): raise AppError(401, str(e))&#10;AppError is caught by app_error_handler() which returns:&#10;  HTTP 401: { &quot;error&quot;: &quot;Invalid login credentials&quot; }&#10;📄 app/routers/auth.py : lines 17-18&#10;📄 app/errors.py : lines 6-9 (AppError class), 35-36 (handler)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="2707" width="280" height="88" as="geometry"/></mxCell>

                <mxCell id="n20" value="Supabase returns a response object with:&#10;  .user    → { id, email, ... }&#10;  .session → { access_token, refresh_token, expires_in, token_type }" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#ECEFF1;strokeColor=#37474F;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="2817" width="340" height="50" as="geometry"/></mxCell>

                <mxCell id="d3" value="user AND session&#10;not None?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="2887" width="180" height="80" as="geometry"/></mxCell>

                <mxCell id="e3" value="Defensive check — if either is None, raise AppError(401, &quot;Invalid email or password&quot;).&#10;In practice Supabase would have thrown above, but this guards against edge cases.&#10;📄 app/routers/auth.py : lines 23-24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="2897" width="280" height="55" as="geometry"/></mxCell>

                <mxCell id="n21" value="Lines 26-34: Build the JSON response. Only exposes minimal fields:&#10;  { user: { id, email }, session: { access_token, refresh_token, expires_in, token_type } }&#10;FastAPI returns this as HTTP 200.&#10;📄 app/routers/auth.py : lines 26-34" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="2987" width="400" height="64" as="geometry"/></mxCell>

                <!-- Error merge -->
                <mxCell id="err_resp" value="All backend errors (400/401) return as HTTP error JSON responses" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="2997" width="250" height="35" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 9: RESPONSE HANDLING                            -->
                <!-- ======================================================= -->
                <mxCell id="sh9" value="RESPONSE ARRIVES BACK IN THE BROWSER" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="3071" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n22" value="authFetch receives the HTTP response (line 11: const res = await fetch(...))" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="3117" width="340" height="35" as="geometry"/></mxCell>

                <mxCell id="d4" value="res.ok?&#10;(status 200-299)" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="3172" width="180" height="80" as="geometry"/></mxCell>

                <mxCell id="e4" value="Lines 20-23: Response is not OK (4xx/5xx).&#10;  const data = await res.json().catch(() =&gt; ({}))  — safely parse error body&#10;  throw new Error(data.error || data.detail || `Request failed: ${res.status}`)&#10;This throw exits authFetch and is caught by signIn's catch block (line 84)&#10;  → return { user: null, error: err instanceof Error ? err : new Error(String(err)) }&#10;📄 src/contexts/AuthContext.tsx : lines 20-23, 84-86" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="3162" width="280" height="100" as="geometry"/></mxCell>

                <mxCell id="n23" value="Lines 20, 24: Response OK — const data = await res.json() returns parsed JSON.&#10;authFetch returns the data object back to signIn.&#10;📄 src/contexts/AuthContext.tsx : lines 20, 24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="320" y="3272" width="380" height="50" as="geometry"/></mxCell>

                <mxCell id="d5" value="data.session&#10;exists?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="3342" width="180" height="80" as="geometry"/></mxCell>

                <mxCell id="n24" value="Lines 77-80: supabase.auth.setSession({ access_token, refresh_token })&#10;  Hands the tokens to the frontend Supabase client. This does three things:&#10;  1. Stores tokens in localStorage (persists across page refreshes/restarts)&#10;  2. Tells Supabase JS &quot;this user is logged in&quot; — enables auto-token-refresh&#10;     (autoRefreshToken: true in client config at supabase/client.ts line 10)&#10;  3. Fires the onAuthStateChange listener registered in step 1 (AuthProvider)&#10;📄 src/contexts/AuthContext.tsx : lines 77-80&#10;📄 src/integrations/supabase/client.ts : lines 7-11" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="3442" width="440" height="118" as="geometry"/></mxCell>

                <mxCell id="n25" value="The onAuthStateChange callback fires (lines 56-60):&#10;  setSession(session) — React state now holds the active session&#10;  setUser(session.user) — React state now holds the logged-in user&#10;  setLoading(false) — auth check complete&#10;Every component calling useAuth() re-renders with the new state.&#10;📄 src/contexts/AuthContext.tsx : lines 55-61" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="3580" width="420" height="88" as="geometry"/></mxCell>

                <mxCell id="n26" value="Line 83: return { user: data.user, error: null }&#10;signIn resolves successfully. Control returns to handleLogin (line 25).&#10;📄 src/contexts/AuthContext.tsx : line 83" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="320" y="3688" width="380" height="50" as="geometry"/></mxCell>

                <!-- ======================================================= -->
                <!-- SECTION 10: BACK IN handleLogin                         -->
                <!-- ======================================================= -->
                <mxCell id="sh10" value="BACK IN handleLogin — CHECKING THE RESULT (Login.tsx lines 27-37)" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="3758" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n27" value="Line 27: if (error) { — checks if signIn returned an error" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="3804" width="340" height="35" as="geometry"/></mxCell>

                <mxCell id="d6" value="error?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="3859" width="140" height="70" as="geometry"/></mxCell>

                <mxCell id="e6" value="Lines 28-29: LOGIN FAILED&#10;  toast.error(error.message) — red Sonner notification shows the error text&#10;    (error.message carries the original Supabase/backend error string)&#10;  setLoading(false) — re-enables button, hides spinner&#10;  User stays on /login page. Can correct credentials and retry.&#10;📄 src/pages/Login.tsx : lines 28-29" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="3849" width="290" height="88" as="geometry"/></mxCell>

                <mxCell id="e7" value="User stays on /login page&#10;Can retry with correct credentials" style="ellipse;whiteSpace=wrap;fontSize=9;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="75" y="3957" width="240" height="50" as="geometry"/></mxCell>

                <mxCell id="d7" value="user&#10;exists?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="3954" width="140" height="70" as="geometry"/></mxCell>

                <mxCell id="n28" value="Lines 31-33: if (user) { — checks user is not null before accessing properties&#10;  analytics.identify(user.id, { email: user.email })&#10;    → calls posthog.identify() — links all future PostHog events to this user ID&#10;    📄 src/lib/analytics.ts : line 5&#10;  analytics.track(&quot;user_signed_in&quot;, { email: user.email })&#10;    → calls posthog.capture() — records this specific login event&#10;    📄 src/lib/analytics.ts : line 9&#10;📄 src/pages/Login.tsx : lines 32-33" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="4049" width="420" height="118" as="geometry"/></mxCell>

                <mxCell id="n29" value="Line 35: toast.success(&quot;Logged in successfully&quot;)&#10;  Green Sonner notification appears at the top of the screen.&#10;📄 src/pages/Login.tsx : line 35" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="4187" width="340" height="50" as="geometry"/></mxCell>

                <mxCell id="n30" value="Line 36: navigate(&quot;/sales&quot;)&#10;  Calls the navigate function (from useNavigate, line 14).&#10;  React Router changes the URL to /sales and renders the matching route.&#10;  /sales is wrapped in &lt;Protected&gt; → ProtectedRoute component runs.&#10;📄 src/pages/Login.tsx : line 36&#10;→ Route defined at src/routes.tsx : line 34" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="4257" width="420" height="88" as="geometry"/></mxCell>

                <mxCell id="n31" value="ProtectedRoute runs: calls useAuth() to read { session, loading }.&#10;  if (loading) → shows &lt;Loader2&gt; spinner&#10;  if (!session) → returns &lt;Navigate to=&quot;/login&quot; replace /&gt;&#10;  if (session) → returns {children} (renders the Sales page)&#10;Session was set in the onAuthStateChange step above, so it passes.&#10;📄 src/components/auth/ProtectedRoute.tsx : lines 9-24&#10;📄 src/routes.tsx : line 34" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="4365" width="420" height="100" as="geometry"/></mxCell>

                <mxCell id="n32" value="Login complete — user is authenticated and viewing the Sales page.&#10;All future API calls include access_token in the Authorization header&#10;via apiFetch() at src/lib/api.ts : lines 5-15." style="ellipse;whiteSpace=wrap;fontSize=9;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="4485" width="400" height="70" as="geometry"/></mxCell>

                <!-- FOOTER -->
