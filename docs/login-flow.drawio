    <diagram id="login-flow" name="Login Authentication Flow">
        <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="3800" math="0" shadow="1">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <mxCell id="hdr" value="" style="rounded=0;fillColor=#263238;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="40" y="0" width="1040" height="80" as="geometry"/></mxCell>
                <mxCell id="hdr-t" value="NIKKOE PLATFORM" style="text;html=1;fontSize=26;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=20;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="4" width="600" height="36" as="geometry"/></mxCell>
                <mxCell id="hdr-s" value="Login Authentication Flow — Step-by-Step with Exact Code References" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=20;" vertex="1" parent="1"><mxGeometry x="40" y="42" width="800" height="20" as="geometry"/></mxCell>

                <!-- STEP 1 -->
                <mxCell id="s1" value="STEP 1 — User clicks &quot;Sign in&quot;" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n1" value="Email and password are stored in React state (useState).&#10;The button is inside a &lt;form&gt;, so clicking it fires onSubmit → handleLogin(e).&#10;📄 Login.tsx : lines 16-18, 52" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="140" width="400" height="50" as="geometry"/></mxCell>

                <!-- STEP 2 -->
                <mxCell id="s2" value="STEP 2 — handleLogin runs (Login.tsx lines 21-37)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="210" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n2" value="Line 22: e.preventDefault() — stops browser page reload&#10;Line 23: setLoading(true) — disables button, shows spinner&#10;Line 25: const { user, error } = await signIn(email, password)&#10;  → signIn comes from useAuth() (line 15) → AuthContext.tsx line 91&#10;📄 Login.tsx : lines 22-25" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="256" width="440" height="78" as="geometry"/></mxCell>

                <!-- STEP 3 -->
                <mxCell id="s3" value="STEP 3 — signIn in AuthContext (AuthContext.tsx lines 91-104)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="354" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n3" value="Wrapped in try/catch — always returns { user, error }, never throws.&#10;Line 93: const data = await authPost(&quot;/auth/login&quot;, { email, password })&#10;  → authPost defined at AuthContext.tsx lines 42-57&#10;Line 95-97: if (data.session) → setStoredToken(data.session.access_token)&#10;  → stores token in localStorage as &quot;nikkoe_access_token&quot; (api.ts line 9)&#10;Line 100: setUser(data.user) — updates React state&#10;Line 101: return { user: data.user, error: null }&#10;📄 AuthContext.tsx : lines 91-104" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="400" width="460" height="118" as="geometry"/></mxCell>

                <!-- STEP 4 -->
                <mxCell id="s4" value="STEP 4 — authPost sends HTTP request (AuthContext.tsx lines 42-57)" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="538" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n4" value="Lines 43-49: fetch(${API_BASE}/auth/login, { method: &quot;POST&quot;, headers, body })&#10;  Body: JSON.stringify({ email, password })&#10;Lines 52-54: if !res.ok → throw new Error(data.error || data.detail)&#10;Line 56: if res.ok → return parsed JSON&#10;📄 AuthContext.tsx : lines 42-57" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="584" width="440" height="78" as="geometry"/></mxCell>
                <mxCell id="en" value="NETWORK ERROR — fetch() throws&#10;Caught by signIn catch (line 102) → returns { user: null, error }" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="594" width="210" height="42" as="geometry"/></mxCell>

                <!-- STEP 5 -->
                <mxCell id="s5" value="STEP 5 — Backend receives request (auth.py lines 11-12, schemas.py lines 150-152)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="682" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n5" value="FastAPI matches POST /api/auth/login → login(body: LoginInput)&#10;Pydantic validates: email: EmailStr, password: str&#10;📄 auth.py : lines 11-12 | schemas.py : lines 150-152" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="728" width="400" height="50" as="geometry"/></mxCell>
                <mxCell id="d1" value="Valid email?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="798" width="180" height="70" as="geometry"/></mxCell>
                <mxCell id="e1" value="ValidationError → HTTP 400&#10;📄 errors.py : lines 39-41" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="808" width="260" height="35" as="geometry"/></mxCell>

                <!-- STEP 6 -->
                <mxCell id="s6" value="STEP 6 — Backend checks credentials (auth.py lines 13-16)" style="rounded=0;fillColor=#37474F;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="888" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n6" value="Line 14: supabase.auth.sign_in_with_password({ email, password })&#10;📄 auth.py : lines 13-16 | dependencies.py : line 4" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#ECEFF1;strokeColor=#37474F;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="340" y="934" width="340" height="42" as="geometry"/></mxCell>
                <mxCell id="d2" value="Credentials correct?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="996" width="180" height="70" as="geometry"/></mxCell>
                <mxCell id="e2" value="Supabase exception → AppError(401) → HTTP 401&#10;📄 auth.py : lines 15-16 | errors.py : lines 6-9, 35-36" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="1001" width="280" height="42" as="geometry"/></mxCell>

                <!-- STEP 7 -->
                <mxCell id="s7" value="STEP 7 — Backend builds response (auth.py lines 18-32)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1086" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n7" value="Lines 21-22: if not user or not session → AppError(401)&#10;Lines 24-32: return { user: {id, email}, session: {access_token, refresh_token, ...} }&#10;📄 auth.py : lines 18-32" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="1132" width="400" height="50" as="geometry"/></mxCell>

                <!-- STEP 8 -->
                <mxCell id="s8" value="STEP 8 — Response arrives in browser (AuthContext.tsx lines 95-100)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1202" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n8" value="Line 96: setStoredToken(data.session.access_token)&#10;  → localStorage.setItem(&quot;nikkoe_access_token&quot;, token) (api.ts line 10)&#10;Line 97: setSession(data.session) — React state updated&#10;Line 100: setUser(data.user) — React state updated&#10;Line 101: return { user: data.user, error: null }&#10;📄 AuthContext.tsx : lines 95-101 | api.ts : lines 9-10" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="1248" width="440" height="88" as="geometry"/></mxCell>

                <!-- STEP 9 -->
                <mxCell id="s9" value="STEP 9 — Back in handleLogin (Login.tsx lines 27-37)" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1356" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="d3" value="error?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="1402" width="140" height="60" as="geometry"/></mxCell>
                <mxCell id="e3" value="Lines 28-29: toast.error(error.message), setLoading(false)&#10;User stays on /login, can retry.&#10;📄 Login.tsx : lines 28-29" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="1399" width="290" height="50" as="geometry"/></mxCell>
                <mxCell id="n9" value="Lines 31-33: analytics.identify + analytics.track&#10;Line 35: toast.success(&quot;Logged in successfully&quot;)&#10;Line 36: navigate(&quot;/sales&quot;) → ProtectedRoute passes → Sales page renders&#10;📄 Login.tsx : lines 31-36 | routes.tsx : line 34 | ProtectedRoute.tsx : lines 9-24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="1487" width="420" height="64" as="geometry"/></mxCell>
                <mxCell id="n10" value="Login complete — user authenticated, viewing Sales page.&#10;All future API calls include token via apiFetch (api.ts lines 17-35)." style="ellipse;whiteSpace=wrap;fontSize=9;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="320" y="1571" width="380" height="55" as="geometry"/></mxCell>

                <!-- DATA TABLE -->
                <mxCell id="tbl" value="" style="rounded=0;fillColor=#ECEFF1;strokeColor=#B0BEC5;" vertex="1" parent="1"><mxGeometry x="140" y="1656" width="740" height="160" as="geometry"/></mxCell>
                <mxCell id="th" value="THE DATA AT EACH BOUNDARY" style="rounded=0;fillColor=#37474F;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="1656" width="740" height="26" as="geometry"/></mxCell>
                <mxCell id="r1" value="User → Browser          Keystrokes → stored in React state (email, password)" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1687" width="740" height="20" as="geometry"/></mxCell>
                <mxCell id="r2" value="Browser → Server        fetch() POST with { email, password } as JSON body" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1710" width="740" height="20" as="geometry"/></mxCell>
                <mxCell id="r3" value="Server → Supabase       sign_in_with_password({ email, password })" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1733" width="740" height="20" as="geometry"/></mxCell>
                <mxCell id="r4" value="Supabase → Server       .user (id, email) + .session (access_token, refresh_token)" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1756" width="740" height="20" as="geometry"/></mxCell>
                <mxCell id="r5" value="Server → Browser        HTTP 200 JSON: { user, session }" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1779" width="740" height="20" as="geometry"/></mxCell>
                <mxCell id="r6" value="Browser → localStorage  setStoredToken(access_token) → &quot;nikkoe_access_token&quot;" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="140" y="1802" width="740" height="20" as="geometry"/></mxCell>

                <mxCell id="ftr" value="" style="rounded=0;fillColor=#263238;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="40" y="1836" width="1040" height="40" as="geometry"/></mxCell>
                <mxCell id="ftrt" value="Login.tsx:52 → handleLogin:21 → signIn:91 → authPost:42 → POST /api/auth/login → LoginInput:150 → sign_in_with_password:14 → setStoredToken:96 → navigate(/sales):36" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1836" width="1040" height="40" as="geometry"/></mxCell>

