                <mxCell id="s1" value="STEP 1 — User clicks &quot;Sign in&quot;" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="136" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="Email and password are stored in React state (useState).&#10;The button is inside a &lt;form&gt;, so clicking it fires onSubmit.&#10;  &lt;form onSubmit={handleLogin}&gt;&#10;📄 Login.tsx : line 52" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="176" width="400" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="STEP 2 — handleLogin starts (Login.tsx lines 21-25)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="260" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="e.preventDefault()&#10;  Stops the browser from reloading the page.&#10;setLoading(true)&#10;  Disables the button and shows a spinner.&#10;📄 Login.tsx : lines 22-23" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="306" width="400" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="n3" value="const { user, error } = await signIn(email, password)&#10;  Calls signIn (from useAuth hook, line 15) and waits for the result.&#10;  signIn comes from AuthContext — never throws, always returns { user, error }.&#10;📄 Login.tsx : line 25&#10;→ signIn defined at AuthContext.tsx : lines 72-87&#10;→ useAuth defined at useAuth.ts : lines 4-9" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="404" width="440" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="STEP 3 — signIn in AuthContext (AuthContext.tsx lines 72-87)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="512" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n4" value="Wrapped in try/catch — guarantees it always returns { user, error }, never throws.&#10;  try: calls authFetch, saves session, returns { user: data.user, error: null }&#10;  catch: wraps the error, returns { user: null, error: Error }&#10;📄 AuthContext.tsx : lines 72-87" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="558" width="400" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="n5" value="const data = await authFetch&lt;AuthSessionResponse&gt;(&quot;/auth/login&quot;, { email, password })&#10;  Calls authFetch with the path and the user's email/password as the body.&#10;📄 AuthContext.tsx : line 74 → authFetch function at lines 9-25" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="642" width="420" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="STEP 4 — authPost sends the HTTP request (AuthContext.tsx lines 44-57)" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="712" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n6" value="authPost(&quot;/auth/login&quot;, { email, password }) sends the HTTP request:&#10;  POST ${API_BASE}/auth/login&#10;  Headers: Content-Type: application/json&#10;  Body: JSON.stringify({ email, password })&#10;  No Authorization header needed — this is the login request itself.&#10;📄 AuthContext.tsx : lines 44-57" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="758" width="440" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="en" value="NETWORK ERROR — fetch() throws&#10;(no internet, DNS failure, server down, timeout)&#10;Caught by signIn's catch → returns { user: null, error }" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="789.5" width="210" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n6b" value="Checks the response.&#10;  If !res.ok → reads error from body, throws new Error(data.error || ...)&#10;  If res.ok  → parses JSON body, returns the data&#10;📄 AuthContext.tsx : lines 50-54" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="300" y="896" width="420" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="s5" value="STEP 5 — Backend receives the request (auth.py lines 11-12, schemas.py lines 138-140)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="980" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n7" value="FastAPI matches POST /api/auth/login to:&#10;  @router.post(&quot;/login&quot;)&#10;  def login(body: LoginInput):&#10;📄 auth.py : lines 11-12" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1026" width="400" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="n8" value="Before login() runs, Pydantic auto-validates the JSON body against LoginInput:&#10;  email: EmailStr — must be valid email format&#10;  password: str — any string&#10;If email format is invalid → 400 error before the function body ever executes.&#10;📄 schemas.py : lines 138-140" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1110" width="420" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="d1" value="Valid email&#10;format?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1208" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e1" value="Pydantic ValidationError → HTTP 400:&#10;  { error: &quot;Validation failed&quot;, details: [...] }&#10;📄 errors.py : lines 39-41" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1218" width="260" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="s6" value="STEP 6 — Backend asks Supabase to check credentials (auth.py lines 13-18)" style="rounded=0;fillColor=#37474F;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1308" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n9" value="supabase.auth.sign_in_with_password({ email: body.email, password: body.password })&#10;  Backend Supabase client (service role key) sends email/password to Supabase.&#10;  Supabase looks up the email in auth.users and compares password against bcrypt hash.&#10;📄 auth.py : lines 14-16&#10;📄 dependencies.py : line 4 (Supabase client with SERVICE_ROLE_KEY)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#ECEFF1;strokeColor=#37474F;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="1354" width="440" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="d2" value="Credentials&#10;correct?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1452" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e2" value="Wrong email or password — Supabase throws an exception.&#10;  except block catches it: raise AppError(401, str(e))&#10;  → app_error_handler returns HTTP 401: { error: &quot;Invalid login credentials&quot; }&#10;📄 auth.py : lines 17-18&#10;📄 errors.py : lines 6-9, 35-36" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1442" width="280" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="STEP 7 — Backend builds the success response (auth.py lines 20-34)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1552" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n10" value="Supabase returned user + session objects. Safety check:&#10;  if not user or not session: raise AppError(401, &quot;Invalid email or password&quot;)&#10;📄 auth.py : lines 20-24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1598" width="400" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="d3" value="user AND session&#10;not None?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1668" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e3" value="Defensive check — user or session is None.&#10;  raise AppError(401, &quot;Invalid email or password&quot;)&#10;📄 auth.py : lines 23-24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1678" width="260" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n11" value="Packages just the fields the frontend needs and returns HTTP 200:&#10;  {&#10;    user: { id: user.id, email: user.email },&#10;    session: { access_token, refresh_token, expires_in, token_type }&#10;  }&#10;📄 auth.py : lines 26-34" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1768" width="420" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="err" value="All backend errors (400/401) return as HTTP error JSON responses" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="50" y="1768" width="220" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="s8" value="STEP 8 — Response arrives back in the browser (AuthContext.tsx lines 87-97)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1876" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n12" value="authFetch receives the HTTP response." style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="340" y="1922" width="340" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="d4" value="res.ok?&#10;(status 200-299)" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1972" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e4" value="Not OK — authFetch reads error from body, throws new Error(data.error).&#10;Caught by signIn's catch → returns { user: null, error }.&#10;📄 AuthContext.tsx : lines 20-23, 84-86" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1975" width="270" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n13" value="res.ok is true — JSON parsed, data returned to signIn.&#10;signIn saves the access_token directly to localStorage:&#10;  setStoredToken(data.session.access_token)&#10;  → localStorage.setItem(&quot;nikkoe_access_token&quot;, token)&#10;Then updates React state: setSession(data.session), setUser(data.user)&#10;📄 AuthContext.tsx : lines 90-94&#10;📄 api.ts : lines 7-9 (setStoredToken)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="2072" width="440" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="n14" value="React state updated — all components using useAuth() re-render:&#10;  session now contains { access_token, refresh_token, expires_in, token_type }&#10;  user now contains { id, email }&#10;  ProtectedRoute sees session is not null → allows access&#10;📄 AuthContext.tsx : lines 90-94" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="2180" width="420" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="n15" value="signIn returns { user: { id, email }, error: null }&#10;📄 AuthContext.tsx : line 83" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="340" y="2288" width="340" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="s9" value="STEP 9 — Back in handleLogin, checking the result (Login.tsx lines 27-37)" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="2343" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="d5" value="error?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="440" y="2389" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="e5" value="LOGIN FAILED:&#10;  toast.error(error.message) — red notification with the error text&#10;  setLoading(false) — re-enables button, hides spinner&#10;User stays on /login, can retry.&#10;📄 Login.tsx : lines 28-29" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="-100" y="2459" width="290" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="e5b" value="User stays on /login page&#10;Can retry with correct credentials" style="ellipse;whiteSpace=wrap;fontSize=9;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="-80" y="2639" width="240" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n16" value="error is null — login succeeded. Three things happen:&#10;&#10;1. analytics.identify(user.id, { email }) — links browser to user in PostHog&#10;   analytics.track(&quot;user_signed_in&quot;, { email }) — records the login event&#10;   📄 Login.tsx : lines 32-33 → analytics.ts : lines 4-9&#10;&#10;2. toast.success(&quot;Logged in successfully&quot;) — green notification&#10;   📄 Login.tsx : line 35&#10;&#10;3. navigate(&quot;/sales&quot;) — sends the user to the Sales page&#10;   📄 Login.tsx : line 36 → routes.tsx : line 34 → ProtectedRoute.tsx : lines 9-24" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="2484" width="440" height="155" as="geometry"/>
