                <mxCell id="d5" value="res.ok?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="440" y="2391" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="e5" value="Not OK → apiFetch throws Error(body.error || &quot;Request failed&quot;).&#10;useMutation onError fires: toast.error(&quot;Failed to add receipt: ...&quot;)&#10;User sees red toast. Form data preserved — can retry.&#10;📄 api.ts : lines 17-19 | mutations.ts : lines 38-40" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
