                <mxCell id="n18" value="ReceiptService.create_receipt(receipt_data, lines_data) at line 21:&#10;  Delegates to self.repo.create(receipt_data, lines_data) — no business logic here&#10;📄 app/services/receipt.py : lines 21-22" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="2900" width="420" height="50" as="geometry"/></mxCell>

                <mxCell id="n19" value="ReceiptRepository.create(receipt, lines) at line 83:&#10;  supabase.rpc(&quot;create_receipt&quot;, { p_receipt: receipt, p_lines: lines }).execute()&#10;  Calls the PostgreSQL RPC function as a single atomic transaction&#10;📄 app/repositories/receipt.py : lines 83-87" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="2970" width="440" height="64" as="geometry"/></mxCell>

                <!-- DATABASE -->
                <mxCell id="sh10" value="DATABASE — create_receipt RPC (20260402_create_receipt_sale_rpcs.sql lines 1-38)" style="rounded=0;fillColor=#0D47A1;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="3054" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n20" value="PL/pgSQL function — runs as one atomic transaction:&#10;&#10;Line 13: INSERT INTO receipts (supplier_id, reference, note)&#10;  VALUES (p_receipt→supplier_id, p_receipt→reference, p_receipt→note)&#10;  RETURNING receipt_id INTO v_receipt_id&#10;&#10;Lines 21-32: FOR EACH line IN jsonb_array_elements(p_lines):&#10;  INSERT INTO receipt_lines (receipt_line_id, receipt_id, item_id, location_id, quantity, unit_cost, currency_code)&#10;  VALUES (gen_random_uuid(), v_receipt_id, line→item_id, line→location_id,&#10;          line→quantity, line→unit_cost, line→currency_code)&#10;&#10;Line 35: SELECT to_jsonb(r.*) FROM receipts r WHERE receipt_id = v_receipt_id → returns created row&#10;📄 supabase/migrations/20260402_create_receipt_sale_rpcs.sql : lines 1-38" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="3100" width="480" height="185" as="geometry"/></mxCell>

                <mxCell id="d4" value="DB insert&#10;succeeds?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="3305" width="180" height="80" as="geometry"/></mxCell>
                <mxCell id="e4" value="FK violation (invalid item_id/location_id/supplier_id) or constraint error.&#10;general_error_handler() maps PG codes:&#10;  23503 → 409 &quot;Referenced record does not exist&quot;&#10;  23505 → 409 &quot;Duplicate record&quot;&#10;📄 app/errors.py : lines 28-32, 44-53" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="3295" width="280" height="78" as="geometry"/></mxCell>

                <mxCell id="n21" value="DB triggers fire after each receipt_lines INSERT:&#10;  create_movement_from_receipt_line → INSERT INTO inventory_movements (type=RECEIPT)&#10;  apply_inventory_movement_to_balances → INCREMENT inventory_balances.quantity_on_hand&#10;Both run inside the same transaction — fully atomic with the insert." style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="3405" width="440" height="64" as="geometry"/></mxCell>

                <mxCell id="n22" value="RPC returns the created receipt row as jsonb.&#10;Response flows back: DB → Repository → Service → Router → HTTP 201 Created" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="3489" width="400" height="42" as="geometry"/></mxCell>

