    <diagram id="receipt-flow" name="Create Receipt Flow">
        <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="3800" math="0" shadow="1">
            <root>
                <mxCell id="0"/>
