                <mxCell id="ftrt" value="AddReceiptForm:124 → validation:93 → api.post:45 → POST /api/receipts → CreateReceiptRequest:110 → ReceiptService:22 → ReceiptRepository:104 → Receipt + Receipt_Stock + Stock → onSuccess:33" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1028" width="1040" height="40" as="geometry"/></mxCell>

