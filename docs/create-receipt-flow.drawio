                <mxCell id="hdr" value="" style="rounded=0;fillColor=#263238;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="40" y="0" width="1040" height="80" as="geometry"/></mxCell>
                <mxCell id="hdr-t" value="NIKKOE PLATFORM" style="text;html=1;fontSize=26;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=20;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="4" width="600" height="36" as="geometry"/></mxCell>
                <mxCell id="hdr-s" value="Create Receipt Flow — Step-by-Step with Exact Code References" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=20;" vertex="1" parent="1"><mxGeometry x="40" y="42" width="800" height="20" as="geometry"/></mxCell>

                <!-- STEP 1 -->
                <mxCell id="s1" value="STEP 1 — User fills the receipt form and clicks &quot;Create receipt&quot;" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n1" value="Form state: supplierId, reference, note, parts[] (item_id, location_id, qty, price, currency_id)&#10;Dropdowns populated by: useSuppliers, useCurrencies, useItems, useLocations, useCurrentUser&#10;&quot;New Part&quot; and &quot;New Location&quot; buttons open inline-create modals.&#10;📄 AddReceiptForm.tsx : lines 78-91, 93-100 (validation)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="140" width="480" height="64" as="geometry"/></mxCell>

                <!-- STEP 2 -->
                <mxCell id="s2" value="STEP 2 — handleSubmit validates and builds payload (AddReceiptForm.tsx lines 124-148)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="224" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n2" value="Line 125: e.preventDefault(), setShowErrors(true)&#10;Line 127: if (!validation.isValid) return — checks per-line fields (item, location, qty, price)&#10;Line 129: Build ReceiptLineInput[] via partLineToInput() — { item_id, location_id, quantity, unit_price, currency_id }&#10;Lines 131-138: addReceipt.mutateAsync({ receipt: { supplier_id, reference, note }, lines })&#10;→ useAddReceipt at mutations.ts : lines 26-42 → api.post(&quot;/receipts&quot;, ...) at api.ts : line 45&#10;📄 AddReceiptForm.tsx : lines 124-148" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="270" width="480" height="88" as="geometry"/></mxCell>
                <mxCell id="d1" value="Valid?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="378" width="140" height="60" as="geometry"/></mxCell>
                <mxCell id="e1" value="Red borders + &quot;Missing: [fields]&quot; on invalid part lines" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="383" width="280" height="35" as="geometry"/></mxCell>

                <!-- STEP 3 -->
                <mxCell id="s3" value="STEP 3 — apiFetch sends HTTP POST (api.ts lines 17-35, 45-46)" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="458" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n3" value="Line 18: Gets Bearer token from localStorage (getStoredToken)&#10;Lines 20-27: fetch(${BASE_URL}/receipts, { method: POST, headers, body })&#10;Lines 29-31: if !res.ok → throw Error&#10;📄 api.ts : lines 17-35" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="504" width="420" height="64" as="geometry"/></mxCell>

                <!-- STEP 4 -->
                <mxCell id="s4" value="STEP 4 — Backend auth + Pydantic validation (receipts.py:34, schemas.py:97-112)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="588" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n4" value="Depends(get_current_user) verifies Bearer token → auth.py : lines 23-57&#10;Pydantic validates CreateReceiptRequest:&#10;  receipt: ReceiptInput (supplier_id: int|None, reference, note)&#10;  lines: list[ReceiptLineInput] (quantity: int gt 0, unit_price: float ge 0, currency_id: int)&#10;📄 receipts.py : lines 33-38 | schemas.py : lines 97-112" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="634" width="460" height="78" as="geometry"/></mxCell>

                <!-- STEP 5 -->
                <mxCell id="s5" value="STEP 5 — Service → Repository → Database (receipt.py:104, Receipt + Receipt_Stock + Stock)" style="rounded=0;fillColor=#0D47A1;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="732" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n5" value="ReceiptRepository.create() at repositories/receipt.py line 104:&#10;  1. Auto-sets dateTime to current UTC timestamp&#10;  2. INSERT INTO Receipt → gets receipt_id&#10;  3. For each line: look up Stock row by (item_id, location_id), create if missing&#10;  4. INSERT INTO Receipt_Stock with stock_id, receipt_id, quantity, unit_price, currency_id&#10;  5. UPDATE Stock SET quantity = quantity + line.quantity (increment)&#10;📄 repositories/receipt.py : lines 104-155" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="778" width="480" height="100" as="geometry"/></mxCell>

                <!-- STEP 6 -->
                <mxCell id="s6" value="STEP 6 — Success: cache invalidation + analytics (mutations.ts:33-37, AddReceiptForm.tsx:140-148)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="898" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n6" value="useMutation onSuccess: invalidateQueries([&quot;receipts&quot;], [&quot;inventory_balances&quot;]), toast.success&#10;analytics.track(&quot;receipt_created&quot;, { line_count, has_supplier, has_reference })&#10;resetForm() clears all state. Receipt complete.&#10;📄 mutations.ts : lines 33-37 | AddReceiptForm.tsx : lines 140-148" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="944" width="440" height="64" as="geometry"/></mxCell>

