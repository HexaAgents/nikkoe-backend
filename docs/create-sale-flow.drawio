                </mxCell>
                <mxCell id="s1" value="STEP 1 — User fills the sale form and clicks &quot;Create sale&quot;" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="136" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="The form fields are stored in React state (useState):&#10;  channelId, customerName — header fields (both optional)&#10;  parts[] — array of { item_id, location_id, quantity, price, currency_code }&#10;Each dropdown is populated by a React Query hook that fetches from the backend:&#10;  Channel &lt;Select&gt; ← useChannels() → GET /api/channels (📄 queries.ts:135)&#10;  Customer combobox ← useCustomers() → GET /api/customers (📄 queries.ts:142)&#10;  Part Number picker ← useItems() → GET /api/items (📄 queries.ts:67)&#10;  Location picker ← useLocations() → GET /api/locations (📄 queries.ts:128)&#10;When user selects a Part, getAutoLocation() (line 95) finds the location&#10;with the lowest stock for that item and auto-sets it.&#10;📄 AddSaleForm.tsx : lines 56-68, 95-102, 111-118, 167" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="176" width="480" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="n1b" value="User clicks &quot;Create sale&quot; → form onSubmit fires handleSubmit(e)&#10;📄 AddSaleForm.tsx : lines 167, 270" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="310" y="356" width="400" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="STEP 2 — handleSubmit validates the form (AddSaleForm.tsx lines 128-131)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="418" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="e.preventDefault() — stops the browser from reloading the page.&#10;setShowErrors(true) — enables red borders on invalid fields.&#10;📄 AddSaleForm.tsx : lines 129-130" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="464" width="400" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n3" value="if (!validation.isValid) return; — checks the useMemo validation (lines 80-93).&#10;For each part line it checks:&#10;  item_id must be non-empty, location_id must be non-empty,&#10;  quantity must be a finite number ≥ 1, unit_price must be a finite number ≥ 0.&#10;If any fail → function returns early, user sees red borders + error text.&#10;📄 AddSaleForm.tsx : lines 80-93, 131" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="534" width="440" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="d1" value="validation&#10;.isValid?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="642" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e1" value="Validation fails — returns early. Red borders + &quot;Missing: [fields]&quot; text.&#10;User stays on form, must fix and retry.&#10;📄 AddSaleForm.tsx : line 131 | PartLineCard.tsx : lines 56, 66-68" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="647" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="STEP 3 — Build the payload and call the API (AddSaleForm.tsx lines 133-147)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="742" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n4" value="Lines 133-139: Maps each part to a SaleLineInput:&#10;  { item_id, location_id, quantity: Math.trunc(Number(...)), unit_price: Number(...), currency_code }&#10;📄 AddSaleForm.tsx : lines 133-139" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="788" width="420" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n5" value="Lines 141-147: await addSale.mutateAsync({ sale: { channel_id, customer_name }, lines })&#10;  addSale is useAddSale() — a useMutation wrapping api.post(&quot;/sales&quot;, ...).&#10;📄 AddSaleForm.tsx : lines 141-147&#10;→ useAddSale at mutations.ts : lines 61-77&#10;→ api.post at api.ts : line 33" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="858" width="440" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="STEP 4 — apiFetch sends the HTTP request (api.ts lines 5-23)" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="956" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n6" value="Line 6: Gets Bearer token from supabase.auth.getSession() (localStorage).&#10;Lines 8-15: Sends the HTTP request:&#10;  POST ${VITE_API_URL}/sales&#10;  Headers: Content-Type: application/json, Authorization: Bearer &lt;token&gt;&#10;  Body: { sale: { channel_id?, customer_name? }, lines: [{item_id, location_id, quantity, unit_price, currency_code}...] }&#10;Lines 17-19: If !res.ok → throws new Error(body.error || &quot;Request failed&quot;)&#10;Line 22: If res.ok → returns parsed JSON.&#10;📄 api.ts : lines 5-23" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="280" y="1002" width="460" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="en" value="NETWORK ERROR — fetch() throws.&#10;Caught by useMutation onError:&#10;  toast.error(&quot;Failed to add sale: ...&quot;)&#10;📄 mutations.ts : lines 73-75" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="-120" y="1029" width="200" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="s5" value="STEP 5 — Backend authenticates, then validates (sales.py line 34, schemas.py lines 105-121)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1140" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n7" value="FastAPI matches POST /api/sales/ → create_sale(body, user).&#10;Depends(get_current_user) runs first — extracts Bearer token,&#10;calls supabase.auth.get_user(token) to verify, loads user profile.&#10;📄 sales.py : lines 33-34 | auth.py : lines 23-57" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1186" width="420" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="d2" value="Token&#10;valid?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1270" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e2" value="Missing/invalid/expired token → HTTPException(401)&#10;📄 auth.py : lines 28, 33, 37, 60-63" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1280" width="270" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="n8" value="Pydantic auto-validates JSON body against CreateSaleRequest:&#10;  sale: SaleInput (customer_name: str|None max 255, channel_id: str|None, note: str|None max 1000)&#10;  lines: list[SaleLineInput] (item_id: str, location_id: str, quantity: int gt 0,&#10;         unit_price: float ge 0, currency_code: str 1-10 chars)&#10;📄 schemas.py : lines 105-121" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="1370" width="440" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="d3" value="Pydantic&#10;valid?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1468" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e3" value="ValidationError → HTTP 400: { error: &quot;Validation failed&quot;, details: [...] }&#10;📄 errors.py : lines 39-41" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1478" width="270" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="s6" value="STEP 6 — Service → Repository → Database RPC (sales.py:35, sale.py:21, sale.py:59, SQL:41-78)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1568" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n9" value="Router calls service.create_sale(body.sale.model_dump(), [line.model_dump() ...])&#10;  model_dump() converts Pydantic models to plain dicts.&#10;📄 sales.py : lines 35-38" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1614" width="400" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n10" value="SaleService.create_sale delegates to self.repo.create(sale_data, lines_data)&#10;📄 services/sale.py : lines 21-22" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1684" width="400" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="n11" value="SaleRepository.create calls the PostgreSQL RPC:&#10;  supabase.rpc(&quot;create_sale&quot;, { p_sale: sale, p_lines: lines }).execute()&#10;📄 repositories/sale.py : lines 59-63" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="300" y="1746" width="420" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="STEP 7 — create_sale RPC runs in the database (SQL lines 41-78)" style="rounded=0;fillColor=#0D47A1;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="40" y="1816" width="1040" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="n12" value="PL/pgSQL function — runs as one atomic transaction:&#10;  Line 52: INSERT INTO sales (sale_id, customer_name, channel_id, note)&#10;    → gen_random_uuid() for sale_id, RETURNING sale_id INTO v_sale_id&#10;  Lines 61-72: FOR EACH line in p_lines:&#10;    INSERT INTO sale_lines (sale_line_id, sale_id, item_id, location_id, quantity, unit_price, currency_code)&#10;  Line 75: SELECT to_jsonb(s.*) → returns the created sale row&#10;📄 20260402_create_receipt_sale_rpcs.sql : lines 41-78" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="280" y="1862" width="460" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="d4" value="DB insert&#10;succeeds?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="1982" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e4" value="FK violation (invalid item_id/location_id/channel_id) or constraint error.&#10;general_error_handler maps PG codes → 409 &quot;Referenced record does not exist&quot;&#10;📄 errors.py : lines 28-32, 44-53" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1982" width="280" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n13" value="DB triggers fire after each sale_lines INSERT:&#10;  create_movement_from_sale_line → INSERT INTO inventory_movements (type=SALE)&#10;  apply_inventory_movement_to_balances → DECREMENT inventory_balances.quantity_on_hand&#10;All runs inside the same atomic transaction." style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="290" y="2082" width="440" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="n14" value="RPC returns created sale row as jsonb → HTTP 201 Created back to browser.&#10;📄 sales.py : line 33 (status_code=201)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="310" y="2166" width="400" height="42" as="geometry"/>
                </mxCell>
