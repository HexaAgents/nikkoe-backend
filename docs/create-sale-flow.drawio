                <mxCell id="d5" value="res.ok?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="440" y="2324" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="e5" value="Not OK → apiFetch throws Error(body.error || &quot;Request failed&quot;).&#10;useMutation onError fires: toast.error(&quot;Failed to add sale: ...&quot;)&#10;User sees red toast. Form data preserved — can retry.&#10;📄 api.ts : lines 17-19 | mutations.ts : lines 73-75" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="2317" width="290" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="s9" value="STEP 9 — Success: cache invalidation, analytics, form reset (mutations.ts:68-72, AddSaleForm.tsx:149-155)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
