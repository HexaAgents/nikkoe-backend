                <mxCell id="hdr" value="" style="rounded=0;fillColor=#263238;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="40" y="0" width="1040" height="80" as="geometry"/></mxCell>
                <mxCell id="hdr-t" value="NIKKOE PLATFORM" style="text;html=1;fontSize=26;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=20;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="4" width="600" height="36" as="geometry"/></mxCell>
                <mxCell id="hdr-s" value="Create Sale Flow — Step-by-Step with Exact Code References" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=20;" vertex="1" parent="1"><mxGeometry x="40" y="42" width="800" height="20" as="geometry"/></mxCell>

                <!-- STEP 1 -->
                <mxCell id="s1" value="STEP 1 — User fills the sale form and clicks &quot;Create sale&quot;" style="rounded=0;fillColor=#1565C0;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n1" value="Form state: channelId, customerId, customerName, parts[] (item_id, location_id, qty, price, currency_id)&#10;Dropdowns populated by: useChannels, useCurrencies, useCustomers, useItems, useLocations, useInventoryOnHand&#10;Channel and Customer are required. Currency is required per line.&#10;📄 AddSaleForm.tsx : lines 57-69, 82-106 (validation)" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="140" width="480" height="64" as="geometry"/></mxCell>

                <!-- STEP 2 -->
                <mxCell id="s2" value="STEP 2 — handleSubmit validates and builds payload (AddSaleForm.tsx lines 141-170)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="224" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n2" value="Line 142: e.preventDefault(), setShowErrors(true)&#10;Line 144: if (!validation.isValid) return — checks channel, customer, and per-line fields&#10;Lines 146-152: Build SaleLineInput[] — { item_id, location_id, quantity, unit_price, currency_id }&#10;Lines 154-160: addSale.mutateAsync({ sale: { channel_id_id, customer_id_id }, lines })&#10;→ useAddSale at mutations.ts : lines 61-77 → api.post(&quot;/sales&quot;, ...) at api.ts : line 45&#10;📄 AddSaleForm.tsx : lines 141-170" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="270" width="480" height="88" as="geometry"/></mxCell>
                <mxCell id="d1" value="Valid?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="378" width="140" height="60" as="geometry"/></mxCell>
                <mxCell id="e1" value="Red errors: &quot;Missing: Channel, Customer&quot; or per-line errors" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="383" width="280" height="35" as="geometry"/></mxCell>

                <!-- STEP 3 -->
                <mxCell id="s3" value="STEP 3 — apiFetch sends HTTP POST (api.ts lines 17-35, 45-46)" style="rounded=0;fillColor=#E65100;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="458" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n3" value="Line 18: Gets Bearer token from localStorage (getStoredToken)&#10;Lines 20-27: fetch(${BASE_URL}/sales, { method: POST, headers, body })&#10;Lines 29-31: if !res.ok → throw Error&#10;📄 api.ts : lines 17-35" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="504" width="420" height="64" as="geometry"/></mxCell>

                <!-- STEP 4 -->
                <mxCell id="s4" value="STEP 4 — Backend auth + Pydantic validation (sales.py:34, schemas.py:115-130)" style="rounded=0;fillColor=#4A148C;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="588" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n4" value="Depends(get_current_user) verifies Bearer token → auth.py : lines 23-57&#10;Pydantic validates CreateSaleRequest:&#10;  sale: SaleInput (customer_id_id: int|None, channel_id_id: int|None, note)&#10;  lines: list[SaleLineInput] (quantity: int gt 0, unit_price: float ge 0, currency_id: int)&#10;📄 sales.py : lines 33-38 | schemas.py : lines 115-130" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="280" y="634" width="460" height="78" as="geometry"/></mxCell>

                <!-- STEP 5 -->
                <mxCell id="s5" value="STEP 5 — Service → Repository → Database (sale.py:96, Sale + Sale_Stock + Stock tables)" style="rounded=0;fillColor=#0D47A1;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="732" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n5" value="SaleRepository.create() at repositories/sale.py line 96:&#10;  1. Auto-sets date to current UTC timestamp&#10;  2. INSERT INTO Sale → gets sale_id&#10;  3. For each line: look up Stock row by (item_id, location_id), create if missing&#10;  4. INSERT INTO Sale_Stock with stock_id, sale_id, quantity, unit_price, currency_id&#10;  5. UPDATE Stock SET quantity = quantity - line.quantity (decrement)&#10;📄 repositories/sale.py : lines 96-147" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="778" width="480" height="100" as="geometry"/></mxCell>

                <!-- STEP 6 -->
                <mxCell id="s6" value="STEP 6 — Success: cache invalidation + analytics (mutations.ts:68-72, AddSaleForm.tsx:162-170)" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="898" width="1040" height="26" as="geometry"/></mxCell>
                <mxCell id="n6" value="useMutation onSuccess: invalidateQueries([&quot;sales&quot;], [&quot;inventory_balances&quot;]), toast.success&#10;analytics.track(&quot;sale_created&quot;, { line_count, channel_id })&#10;resetForm() clears all state. Sale complete.&#10;📄 mutations.ts : lines 68-72 | AddSaleForm.tsx : lines 162-170" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="944" width="440" height="64" as="geometry"/></mxCell>

