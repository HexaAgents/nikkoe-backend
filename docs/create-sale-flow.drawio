                    <mxGeometry x="50" y="2082" width="220" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="s8" value="STEP 8 — Response arrives back in the browser" style="rounded=0;fillColor=#2E7D32;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1">
