                <mxCell id="n18" value="SaleService.create_sale(sale_data, lines_data) at line 21:&#10;  Delegates to self.repo.create(sale_data, lines_data) — no business logic here&#10;📄 app/services/sale.py : lines 21-22" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="300" y="2955" width="420" height="50" as="geometry"/></mxCell>

                <mxCell id="n19" value="SaleRepository.create(sale, lines) at line 59:&#10;  supabase.rpc(&quot;create_sale&quot;, { p_sale: sale, p_lines: lines }).execute()&#10;  Calls the PostgreSQL RPC function as a single atomic transaction&#10;📄 app/repositories/sale.py : lines 59-63" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="3025" width="440" height="64" as="geometry"/></mxCell>

                <!-- DATABASE -->
                <mxCell id="sh10" value="DATABASE — create_sale RPC (20260402_create_receipt_sale_rpcs.sql lines 41-78)" style="rounded=0;fillColor=#0D47A1;strokeColor=none;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#FFFFFF;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="3109" width="1040" height="26" as="geometry"/></mxCell>

                <mxCell id="n20" value="PL/pgSQL function — runs as one atomic transaction:&#10;&#10;Line 52: INSERT INTO sales (sale_id, customer_name, channel_id, note)&#10;  VALUES (gen_random_uuid(), p_sale→customer_name, p_sale→channel_id, p_sale→note)&#10;  RETURNING sale_id INTO v_sale_id&#10;&#10;Lines 61-72: FOR EACH line IN jsonb_array_elements(p_lines):&#10;  INSERT INTO sale_lines (sale_line_id, sale_id, item_id, location_id, quantity, unit_price, currency_code)&#10;  VALUES (gen_random_uuid(), v_sale_id, line→item_id, line→location_id,&#10;          line→quantity, line→unit_price, line→currency_code)&#10;&#10;Line 75: SELECT to_jsonb(s.*) FROM sales s WHERE sale_id = v_sale_id → returns created row&#10;📄 supabase/migrations/20260402_create_receipt_sale_rpcs.sql : lines 41-78" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="3155" width="480" height="185" as="geometry"/></mxCell>

                <mxCell id="d4" value="DB insert&#10;succeeds?" style="rhombus;whiteSpace=wrap;fontSize=10;fontStyle=1;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="3360" width="180" height="80" as="geometry"/></mxCell>
                <mxCell id="e4" value="FK violation (invalid item_id/location_id/channel_id) or constraint error.&#10;general_error_handler() maps PG codes:&#10;  23503 → 409 &quot;Referenced record does not exist&quot;&#10;  23505 → 409 &quot;Duplicate record&quot;&#10;📄 app/errors.py : lines 28-32, 44-53" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="50" y="3350" width="280" height="78" as="geometry"/></mxCell>

                <mxCell id="n21" value="DB triggers fire after each sale_lines INSERT:&#10;  create_movement_from_sale_line → INSERT INTO inventory_movements (type=SALE)&#10;  apply_inventory_movement_to_balances → DECREMENT inventory_balances.quantity_on_hand&#10;Both run inside the same transaction — fully atomic with the insert." style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E3F2FD;strokeColor=#0D47A1;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="290" y="3460" width="440" height="64" as="geometry"/></mxCell>

                <mxCell id="n22" value="RPC returns the created sale row as jsonb.&#10;Response flows back: DB → Repository → Service → Router → HTTP 201 Created" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#EDE7F6;strokeColor=#4A148C;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="310" y="3544" width="400" height="42" as="geometry"/></mxCell>

