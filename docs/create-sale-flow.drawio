                <mxCell id="n3" value="Hooks run (lines 56-62):&#10;  const addSale = useAddSale()&#10;    → useMutation wrapping api.post(&quot;/sales&quot;, ...) — handles submit, success, error&#10;    → defined at src/hooks/mutations.ts : lines 61-77&#10;  const { data: channels } = useChannels()&#10;    → GET /api/channels → populates Channel dropdown&#10;    → defined at src/hooks/queries.ts : line 135&#10;  const { data: items } = useItems()&#10;    → GET /api/items → populates Part Number picker&#10;    → defined at src/hooks/queries.ts : line 67&#10;  const { data: locations } = useLocations()&#10;    → GET /api/locations → populates Location picker&#10;    → defined at src/hooks/queries.ts : line 128&#10;  const { data: inventoryOnHand } = useInventoryOnHand()&#10;    → GET /api/inventory/on-hand → used by getAutoLocation()&#10;    → defined at src/hooks/queries.ts : line 157&#10;  const { data: customers } = useCustomers()&#10;    → GET /api/customers → populates Customer combobox&#10;    → defined at src/hooks/queries.ts : line 142&#10;  const addCustomer = useAddCustomer()&#10;    → POST /api/customers to create new customer inline&#10;    → defined at src/hooks/mutations.ts : line 233&#10;📄 src/components/sales/AddSaleForm.tsx : lines 56-62" style="rounded=1;whiteSpace=wrap;fontSize=9;fontFamily=Helvetica;fontColor=#1a1a1a;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="270" y="369" width="480" height="310" as="geometry"/></mxCell>

