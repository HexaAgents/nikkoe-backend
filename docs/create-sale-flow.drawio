                <mxCell id="ftrt" value="AddSaleForm:141 → validation:82 → api.post:45 → POST /api/sales → CreateSaleRequest:128 → SaleService:22 → SaleRepository:96 → Sale + Sale_Stock + Stock → onSuccess:68" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#90A4AE;align=left;spacingLeft=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1028" width="1040" height="40" as="geometry"/></mxCell>

